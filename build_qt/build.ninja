  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\Projects\ghostty-blackhole-main-main\build_qt && C:\msys64\ucrt64\bin\cmake.exe -DCMAKE_INSTALL_DO_STRIP=1 -P cmake_install.cmake"
  DESC = Installing the project stripped...
  pool = console
  restat = 1

