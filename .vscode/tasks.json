{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-g",
                "-O0",
                "-o",
                "${workspaceFolder}/build/blackhole.exe",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/capture_wgc.cpp",
                "${workspaceFolder}/src/capture_dxgi.cpp",
                "${workspaceFolder}/src/gl_texture.cpp",
                "${workspaceFolder}/src/gui_config.cpp",
                "${workspaceFolder}/src/imgui/imgui.cpp",
                "${workspaceFolder}/src/imgui/imgui_draw.cpp",
                "${workspaceFolder}/src/imgui/imgui_widgets.cpp",
                "${workspaceFolder}/src/imgui/imgui_tables.cpp",
                "${workspaceFolder}/src/imgui/imgui_impl_glfw.cpp",
                "${workspaceFolder}/src/imgui/imgui_impl_opengl3.cpp",
                "-Isrc/imgui",
                "-IC:/msys64/ucrt64/include",
                "-LC:/msys64/ucrt64/lib",
                "-lglfw3",
                "-lopengl32",
                "-lgdi32",
                "-ld3d11",
                "-ldxgi",
                "-lruntimeobject",
                "-ldwmapi",
                "-lcomctl32",
                "-mwindows"
            ],
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "new" },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                }
            }
        },
        {
            "label": "build-release",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-O2",
                "-o",
                "${workspaceFolder}/build/blackhole.exe",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/capture_wgc.cpp",
                "${workspaceFolder}/src/capture_dxgi.cpp",
                "${workspaceFolder}/src/gl_texture.cpp",
                "${workspaceFolder}/src/gui_config.cpp",
                "${workspaceFolder}/src/imgui/imgui.cpp",
                "${workspaceFolder}/src/imgui/imgui_draw.cpp",
                "${workspaceFolder}/src/imgui/imgui_widgets.cpp",
                "${workspaceFolder}/src/imgui/imgui_tables.cpp",
                "${workspaceFolder}/src/imgui/imgui_impl_glfw.cpp",
                "${workspaceFolder}/src/imgui/imgui_impl_opengl3.cpp",
                "-Isrc/imgui",
                "-IC:/msys64/ucrt64/include",
                "-LC:/msys64/ucrt64/lib",
                "-lglfw3",
                "-lopengl32",
                "-lgdi32",
                "-ld3d11",
                "-ldxgi",
                "-lruntimeobject",
                "-ldwmapi",
                "-lcomctl32",
                "-mwindows"
            ],
            "group": "none",
            "presentation": { "reveal": "silent" },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1, "line": 2, "column": 3, "severity": 4, "message": 5
                }
            }
        },
        {
            "label": "Run Always",
            "type": "shell",
            "command": "${workspaceFolder}/build/blackhole.exe",
            "group": "none",
            "presentation": { "reveal": "never" },
            "problemMatcher": []
        },
        {
            "label": "Kill Blackhole",
            "type": "shell",
            "command": "taskkill /f /im blackhole.exe",
            "group": "none",
            "problemMatcher": []
        }
    ]
}