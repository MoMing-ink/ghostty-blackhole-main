{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Blackhole",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/blackhole.exe",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build-debug",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}